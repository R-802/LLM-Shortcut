# Created by setup.bat - do not commit .env

# Python (required for scripts)
PYTHON_EXE=C:\Users\You\miniconda3\python.exe
PYTHONW_EXE=C:\Users\You\miniconda3\pythonw.exe

# Notifications (optional)
NTFY_ENABLED=true
NTFY_TOPIC=your-ntfy-topic-name
# To disable: NTFY_ENABLED=false and leave NTFY_TOPIC empty

# LLM API keys (at least one recommended; more = better failover)
GEMINI_API_KEY=
GROQ_API_KEY=
HF_TOKEN=
OPENROUTER_API_KEY=

# Hotkey shortcut (modifier+key; default ctrl+b)
HOTKEY=ctrl+b

# Chroma Cloud embeddings (optional; uses $5 credit — better than local MiniLM)
# Get a key at https://www.trychroma.com — do not commit the real key.
# CHROMA_API_KEY=
# RAG_CHROMA_EMBEDDINGS=true
# RAG_CHROMA_EMBED_MODEL=BAAI/bge-m3
# RAG_CHROMA_EMBED_MODELS=BAAI/bge-m3,Qwen/Qwen3-Embedding-0.6B
# RAG_EMBED_INSTRUCTIONS=Represent the text for retrieval and semantic search over study materials.
# RAG_EMBED_TIMEOUT_S=60
# RAG_BUILD_TIMEOUT_S=900

# RAG: semantic search over files in context/ (local ChromaDB index)
# With RAG enabled, Clip Assist auto-rebuilds the index when context/ changes (no restart).
# scripts\index_rag.bat is optional (manual rebuild; stops the app first on Windows).
RAG_ENABLED=false
RAG_TOP_K=5
RAG_CHUNK_CHARS=700
RAG_CHUNK_OVERLAP=120
# RAG_WATCH_ENABLED=true
# RAG_WATCH_INTERVAL_S=15
# RAG_WATCH_DEBOUNCE_S=3
# Max chars when loading a named file from disk before index catches up (default 12000).
# RAG_NAMED_FILE_MAX_CHARS=12000
# Max total chars of study material sent per request (default 10000).
# RAG_PROMPT_MAX_CHARS=10000
# Seconds to wait for Chroma lock before disk fallback (default 3).
# RAG_LOCK_TIMEOUT_S=3
# Max chars of user prompt written to app.log per request (default 8000).
# LOG_PROMPT_MAX_CHARS=8000
# RAG_QUERY_TIMEOUT_S=30
# Max cosine distance for a chunk to count as relevant (0-2, lower=stricter). Default 0.82.
# Unrelated questions send no context when best match is above this.
# RAG_MAX_DISTANCE=0.82
# Stricter limit for questions that do not name a file (default 0.68). Stops unrelated chunks.
# RAG_MAX_DISTANCE_OPEN=0.62
# Min distinctive keyword overlaps for open queries (default 2).
# RAG_OPEN_TERM_MIN_HITS=2

# Max chars when RAG fails and all context/ files are loaded (default 12000). Not used for RAG chunks.
# CONTEXT_FALLBACK_MAX_CHARS=12000

# Windows scheduled task name (optional)
TASK_NAME=ClipAssist

# Max seconds per hotkey request (context load + LLM). Default 90.
# REQUEST_TIMEOUT_S=90
# ROUTER_DEADLINE_S=45
