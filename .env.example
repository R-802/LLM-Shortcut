# Created by setup.bat - do not commit .env

# Python (required for scripts)
PYTHON_EXE=C:\Users\You\miniconda3\python.exe
PYTHONW_EXE=C:\Users\You\miniconda3\pythonw.exe

# Notifications (optional)
NTFY_ENABLED=true
NTFY_TOPIC=your-ntfy-topic-name
# To disable: NTFY_ENABLED=false and leave NTFY_TOPIC empty

# LLM API keys (at least one recommended; more = better failover)
GEMINI_API_KEY=
GROQ_API_KEY=
HF_TOKEN=
OPENROUTER_API_KEY=

# Hotkey shortcut (modifier+key; default ctrl+b)
HOTKEY=ctrl+b

# RAG: semantic search over files in context/ (local ChromaDB index)
# RAG needs a working index (scripts\index_rag.bat). Set false if Chroma queries fail under pythonw.
RAG_ENABLED=false
RAG_TOP_K=5
RAG_CHUNK_CHARS=700
RAG_CHUNK_OVERLAP=120
# RAG_QUERY_TIMEOUT_S=30

# Max chars when RAG fails and all context/ files are loaded (default 12000). Not used for RAG chunks.
# CONTEXT_FALLBACK_MAX_CHARS=12000

# Windows scheduled task name (optional)
TASK_NAME=ClipAssist

# Max seconds per hotkey request (context load + LLM). Default 90.
# REQUEST_TIMEOUT_S=90
# ROUTER_DEADLINE_S=45
